# ── Local Dev (docker-compose) ──────────────────────────
DATABASE_URL=postgresql://drishti_user:drishti_pass@localhost:5432/drishti

# ── Production ──────────────────────────────────────────
# DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# Redis — local Docker (docker compose). For prod use an Upstash rediss:// URL.
REDIS_URL=redis://localhost:6379
# REDIS_URL=rediss://default:[password]@[host].upstash.io:6379

# Qdrant — local Docker (docker compose). For prod use a Qdrant Cloud URL (must
# end with :6333) + API key.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
# QDRANT_URL=https://[id].[region].aws.cloud.qdrant.io:6333

# ── Embeddings (RAG) ────────────────────────────────────
# Runs fully locally (all-MiniLM-L6-v2, 384-dim) — free, offline, no API key.
EMBED_DIM=384
EMBED_MODEL=Xenova/all-MiniLM-L6-v2

# ── LLM Providers (all free) ────────────────────────────
# Reasoning chain: Groq (primary, multi-key rotation) → Gemini → Together.
# Only GROQ_API_KEY is REQUIRED to run locally; the rest are optional fallbacks.
# Add more Groq keys (… _2, _3, up to _10), ideally from separate accounts, to
# pool the free-tier daily quota — the router rotates past any key hitting 429.
GROQ_API_KEY=your-groq-api-key
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional fallback. Gemini also supports multiple keys (… _2, _3) with rotation.
# Use gemini-2.5-flash: gemini-2.0-flash returns free-tier "limit: 0" on many projects.
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash

# Optional fallback (leave blank to skip — the app starts fine without it).
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo-Free

# Auth
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Email (IMAP) — optional, skip if not testing email ingestion
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=complaints@yourtelecom.com
IMAP_PASSWORD=your-gmail-app-password
IMAP_MAILBOX=INBOX
IMAP_POLL_INTERVAL_MS=30000

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
