# ── Local Dev (docker-compose) ──────────────────────────
DATABASE_URL=postgresql://drishti_user:drishti_pass@localhost:5432/drishti

# ── Production ──────────────────────────────────────────
# DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# Redis — Upstash (works for both local and prod)
REDIS_URL=rediss://:[password]@[host].upstash.io:6379

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
# QDRANT_URL=https://[id].[region].gcp.cloud.qdrant.io

# ── Embeddings (RAG) ────────────────────────────────────
# Runs fully locally (all-MiniLM-L6-v2, 384-dim) — free, offline, no API key.
EMBED_DIM=384
EMBED_MODEL=Xenova/all-MiniLM-L6-v2

# ── LLM Providers (all free) ────────────────────────────
# Reasoning chain: Groq (primary, multi-key rotation) → Gemini → Together.
# Add up to 10 Groq keys (ideally from separate accounts) to pool the free-tier
# quota — the router rotates past any key that gets rate-limited (HTTP 429).
GROQ_API_KEY=your-groq-api-key
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_MODEL=llama-3.3-70b-versatile

TOGETHER_API_KEY=your-together-api-key
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo-Free

GEMINI_API_KEY=your-gemini-api-key
GEMINI_VISION_MODEL=gemini-2.0-flash
GEMINI_MODEL=gemini-2.0-flash

# Auth
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Email (IMAP) — optional, skip if not testing email ingestion
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=complaints@yourtelecom.com
IMAP_PASSWORD=your-gmail-app-password
IMAP_MAILBOX=INBOX
IMAP_POLL_INTERVAL_MS=30000

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
