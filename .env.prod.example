# Production env for docker-compose.prod.yml — copy to .env.prod and fill in.
# NEVER commit .env.prod.

# Postgres — Neon DIRECT connection string (not the -pooler one; keep ?sslmode=require)
DATABASE_URL=postgresql://neondb_owner:[password]@ep-[id].[region].aws.neon.tech/neondb?sslmode=require

# Redis — self-hosted in docker-compose.prod.yml (no command quota).
# REDIS_URL is set there (redis://redis:6379) and overrides anything here, so
# you can leave this blank. (To use Upstash instead, set rediss://… AND remove
# the REDIS_URL override from docker-compose.prod.yml.)
REDIS_URL=

# Qdrant — Qdrant Cloud free tier. Cluster URL MUST end with :6333 (no trailing slash).
QDRANT_URL=https://[cluster-id].[region].aws.cloud.qdrant.io:6333
QDRANT_API_KEY=

# Embeddings run locally on the server (no key).
EMBED_DIM=384
EMBED_MODEL=Xenova/all-MiniLM-L6-v2

# LLM — Groq (multi-key rotation). Add keys from separate accounts (… _2, _3, _4, _5)
# to pool the free-tier quota; the router rotates across all of them.
GROQ_API_KEY=
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional LLM fallback — also multi-key (GEMINI_API_KEY, _2, _3 …), rotated on quota.
# Use gemini-2.5-flash: gemini-2.0-flash has free-tier limit 0 on many projects.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash

# Auth — long random string
JWT_SECRET=

# CORS / WebSocket origin — your deployed Vercel frontend URL
FRONTEND_URL=https://your-app.vercel.app
